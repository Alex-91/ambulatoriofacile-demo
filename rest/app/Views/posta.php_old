function buildForwardLabel(?string $inoltratoJson, string $fallbackOriginalSender = ''): ?string {
    if (!$inoltratoJson) return null;

    $meta = json_decode($inoltratoJson, true);
    if (!is_array($meta)) return null;

    $forName = trim((string)($meta['for_client_name'] ?? '')); // mittente originale (quando disponibile)
    if ($forName === '') {
        $forName = trim($fallbackOriginalSender);
    }
    $byRole  = (string)($meta['by_role'] ?? '');               // P/S/I

    if ($forName === '' || !in_array($byRole, ['P','S','I'], true)) return null;

    $perConto = match ($byRole) {
        'S' => 'Inoltro dalla segreteria per conto di ',
        'I' => "Inoltro dell'infermiere per conto di ",
        'P' => 'Inoltro del medico per conto di ',
        default => 'Inoltro per conto di ',
    };

    return $perConto.$forName;
}


