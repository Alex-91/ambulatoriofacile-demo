<IfModule mod_rewrite.c>
    RewriteEngine On
    AcceptPathInfo On

    # Blocca file nascosti e percorsi che non devono mai essere esposti dal webroot.
    RewriteRule (^|/)\.(?!well-known/) - [F,L]
    RewriteRule ^(?:app/)?(?:docker|dist|node_modules|repo_friend_main|src|vendor|rest)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:app/)?(?:Dockerfile|composer\.(?:json|lock)|package(?:-lock)?\.json|coolify\.env\.example|README_DEPLOY\.md)$ - [F,L,NC]
    RewriteRule ^(?:app/)?[^/]+\.(?:env|ini|log|sql|tar|gz|zip)$ - [F,L,NC]

    # Permette la home, la root /app e gli asset pubblici richiesti dal frontend/PWA.
    RewriteRule ^$ index.php [L,QSA]
    RewriteRule ^app/?$ index.php [L,QSA]
    RewriteRule ^(?:index\.php(?:/.*)?|manifest\.json|sw\.js|favicon\.ico)$ - [L,NC]
    RewriteRule ^(?:public|icons|js)/.+$ - [L,NC]
    RewriteRule ^(?:app|demo)/(manifest\.json|sw\.js|favicon\.ico)$ $1 [L,NC]
    RewriteRule ^(?:app|demo)/(public|icons|js)/(.+)$ $1/$2 [L,NC]

    # Qualsiasi altro file o directory esistente non deve essere servito direttamente.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [F,L]

    # Supporta l area privata sotto /app mantenendo il browser su quel path.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^app/(.*)$ index.php/$1 [L,QSA]

    # Se il file o la cartella non esistono, reindirizza a index.php.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

