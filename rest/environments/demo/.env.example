# Demo environment template
# Use this file only in a dedicated demo copy of the product.
# Never reuse the farmacia environment or database.

CI_ENVIRONMENT = development
app.baseURL = 'http://localhost/demo-app/public/'
app.indexPage = ''
APP_CANONICAL_URL = 'https://demo.ambulatoriofacile.example/'

database.default.hostname = localhost
database.default.database = ambulatoriofacile_demo
database.default.username = root
database.default.password = root
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.DB_ENCRYPTION_KEY = change-demo-key
DB_ENCRYPTION_KEY = change-demo-key
DB_ENCRYPTION_MODE = aes-256-cbc

FILE_CRYPT_ALGO = AES-256-CBC
FILE_CRYPT_KEY = change-demo-file-key
FILE_CRYPT_IV = 1234567890abcdef
crypto.key_hex =
crypto.iv_hex =

email.fromEmail = demo@ambulatoriofacile.example
email.fromName = 'AmbulatorioFacile'
email.protocol = smtp
email.SMTPHost = smtp.example.com
email.SMTPUser = demo@ambulatoriofacile.example
email.SMTPPass = change-me
email.SMTPPort = 465
email.SMTPCrypto = ssl
email.SMTPTimeout = 10
email.mailType = text
email.charset = UTF-8
demo.requestNotificationRecipients =

SMS_API_TOKEN =
SMS_USERNAME =
SMS_PASSWORD =
SMS_ULTRAMSG_URL =
SMS_BATCH_DELAY_MS = 900000
REMINDER_CHANNEL = wa
CRON_ACCESS_TOKEN = change-demo-token

PUSH_MODE = remote
PUSH_REMOTE_URL = https://push.example.com/api/send
PUSH_REMOTE_API_KEY = change-demo-push-key
VAPID_PUBLIC_KEY =
VAPID_SUBJECT = mailto:demo@ambulatoriofacile.example

AUTH_HANDOFF_SECRET = change-demo-handoff-secret
AUTH_HANDOFF_ISSUER = ambulatoriofacile-demo
AUTH_HANDOFF_CLOCK_SKEW = 30
AUTH_HANDOFF_MAX_LIFETIME = 120

PRODUCT_BRAND_NAME = 'AmbulatorioFacile'
PRODUCT_BRAND_SHORT_NAME = 'AmbulatorioFacile'
PRODUCT_BRAND_MANIFEST_DESCRIPTION = 'Piattaforma operativa per agenda, team, promemoria e comunicazione.'
