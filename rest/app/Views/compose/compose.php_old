  // âœ… BOZZE SOLO DOTTORI/PERSONALE (NON paziente)
  $draftEnabled = !$isPatient;

  // quando riapri bozza, il controller puÃ² passare:
  // $draftId (int), $draftData (array con 'testo' decriptato + 'meta' ecc)
  $draftId   = isset($draftId) ? (int)$draftId : 0;
  $draftData = $draftData ?? null;

  // id_message (se lo passi giÃ  dal controller, o pre-assegnato da contatore)
  $id_message = isset($id_message) ? (int)$id_message : 0;

  // âœ… Prefill testo server-side (fallback: cosÃ¬ lo vedi anche se JS/WYSIHTML5 non Ã¨ pronto)
  $prefillText = '';
  if ($draftEnabled && !empty($draftData) && is_array($draftData)) {
      if (!empty($draftData['testo']))         $prefillText = (string)$draftData['testo'];
      elseif (!empty($draftData['body']))      $prefillText = (string)$draftData['body'];
      elseif (!empty($draftData['message']))   $prefillText = (string)$draftData['message'];
      elseif (!empty($draftData['testo_dec'])) $prefillText = (string)$draftData['testo_dec'];
  }
?>

