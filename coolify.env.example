# Use this file as copy/paste source for Coolify environment variables.
# Recommended demo URL:
# - easiest: https://demo.ambulatoriofacile.it/
# - if the whole root domain is on Coolify: https://ambulatoriofacile.it/demo/

CI_ENVIRONMENT=production
RUN_MIGRATIONS=1
APP_MAINTENANCE_MODE=0

app.baseURL=https://demo.ambulatoriofacile.it/
APP_CANONICAL_URL=https://demo.ambulatoriofacile.it/
LEGACY_UPLOAD_PATH=/var/www/html/upload

database.default.hostname=CHANGE_ME
database.default.database=CHANGE_ME
database.default.username=CHANGE_ME
database.default.password=CHANGE_ME
database.default.DBDriver=MySQLi
database.default.DBPrefix=
database.default.port=3306

database.default.DB_ENCRYPTION_KEY=CHANGE_ME_LONG_SECRET
DB_ENCRYPTION_KEY=CHANGE_ME_LONG_SECRET
DB_ENCRYPTION_MODE=aes-256-cbc

FILE_CRYPT_ALGO=AES-256-CBC
FILE_CRYPT_KEY=CHANGE_ME_FILE_SECRET
FILE_CRYPT_IV=1234567890abcdef

email.fromEmail=noreply@ambulatoriofacile.it
email.fromName=Ambulatorio Facile
email.protocol=smtp
email.SMTPHost=CHANGE_ME
email.SMTPUser=CHANGE_ME
email.SMTPPass=CHANGE_ME
email.SMTPPort=465
email.SMTPCrypto=ssl
email.SMTPTimeout=10
email.mailType=text
email.charset=UTF-8

AUTH_HANDOFF_SECRET=CHANGE_ME
AUTH_HANDOFF_ISSUER=ambulatoriofacile-demo
AUTH_HANDOFF_CLOCK_SKEW=30
AUTH_HANDOFF_MAX_LIFETIME=120

CRON_ACCESS_TOKEN=CHANGE_ME
PUSH_MODE=remote
PUSH_REMOTE_URL=CHANGE_ME
PUSH_REMOTE_API_KEY=CHANGE_ME
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:noreply@ambulatoriofacile.it

