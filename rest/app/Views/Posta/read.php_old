    <script src="<?= base_url('public/plugins/slimScroll/jquery.slimscroll.min.js') ?>"></script>
    <script src="<?= base_url('public/plugins/fastclick/fastclick.min.js') ?>"></script>
    <script src="<?= base_url('public/dist/js/app.min.js') ?>"></script>
    <script src="<?= base_url('public/plugins/iCheck/icheck.min.js') ?>"></script>

    <script>
      // Loader come nella inbox
      (function() {
        var loader = $('#page-loader');

        function showLoader(){ loader.stop(true,true).fadeIn(100); }
        function hideLoader(){ loader.stop(true,true).fadeOut(150); }

        // Mostra loader SOLO per link normali (niente per .no-loader o target="_blank")
        $(document).on('click', 'a[href]:not([href^="#"]):not([target="_blank"]):not(.no-loader)', function(e){
          if (e.ctrlKey || e.shiftKey || e.metaKey || (this.href && this.href.indexOf('javascript:') === 0)) return;
          var $a = $(this);
          if ($a.attr('data-toggle') === 'dropdown' || $a.attr('data-toggle') === 'collapse' || $a.data('widget') === 'collapse') return;
          showLoader();
        });

        $(document).on('submit', 'form:not(.no-loader)', function(){ showLoader(); });
        window.addEventListener('beforeunload', function(){ showLoader(); });
        $(window).on('load', hideLoader);
      })();

      // Conferma eliminazione
      $(document).on('click', '.btn-delete', function(e){
        if(!confirm('Eliminare questo messaggio?')) {
          e.preventDefault();
        }
      });

      // Shortcut tastiera
      document.addEventListener('keydown', function(e){
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
        var replyUrl  = "<?= site_url('posta/reply/' . urlencode($uid)) ?>";
        var fwdUrl    = "<?= site_url('posta/forward/' . urlencode($uid)) ?>";
        var delUrl    = "<?= site_url('posta/delete/' . urlencode($uid)) ?>";
        var backUrl   = "<?= $backUrl ?>";
        if (e.key === 'r' || e.key === 'R') { window.location = replyUrl; }
        else if (e.key === 'f' || e.key === 'F') { window.location = fwdUrl; }
        else if (e.key === 'Backspace') { window.location = backUrl; }
        else if (e.key === 'Delete') {
          if (confirm('Eliminare questo messaggio?')) window.location = delUrl;
        }
      });
    </script>
  </body>
</html>
