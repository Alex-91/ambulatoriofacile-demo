<?php
/** @var array|null  $thread */   // elenco messaggi del thread, ordinati per data ASC
/** @var string      $src */
/** @var int|null    $selectedDoctorId */
/** @var int|null    $tipoPers */
/** @var bool|null   $isSegOrInf */

use CodeIgniter\I18n\Time;

$tz = 'Europe/Rome';

/**
 * Thread completo
 */
$threadMsgs = (isset($thread) && is_array($thread)) ? $thread : [];

/**
 * Messaggio â€œcorrenteâ€ per header/azioni:
 * usiamo il primo elemento del thread (il controller garantisce che sia il root/main)
 */
$current = !empty($threadMsgs) ? $threadMsgs[0] : null;
$isClient = ((int)(session()->get('tipoUser') ?? 0) === 3);
// Se per qualche motivo il thread Ã¨ vuoto, mettiamo valori di fallback
$dataDT = ($current && isset($current['dataora'])) ? Time::parse($current['dataora'], $tz) : null;
$when   = $dataDT ? $dataDT->toLocalizedString('d MMM y HH:mm') : '';
$human  = $dataDT ? $dataDT->humanize() : '';

$fromName = 'Mittente';
if ($current) {
    $fromName = trim(
        ($current['mitt_prefix']         ?? '') . ' ' .
        ($current['mittente_cognome']    ?? '') . ' ' .
        ($current['mittente_nome']       ?? '')
    );
    if ($fromName === '') {
        $fromName = 'Mittente';
    }
}

$fromEmail = $current['email']  ?? '';
$toName    = session()->get('nome_visualizzato') ?: 'Tu';
$subject   = $current['oggetto'] ?? '';

$forwardNote = '';
if ($current && !empty($current['inoltrato'] ?? '')) {
    $forwardNote = (string)$current['inoltrato'];
}

// UID composto per azioni (es: M:123)
$mainId = $current['id_message'] ?? ($current['uid'] ?? null);
$uid    = ($src ?? 'M') . ':' . ($mainId ?: '0');
$box = $box ?? 'inbox';
$backUrl = ($box === 'sent') ? site_url('inviata') : site_url('posta');

// Menu e dottori (come nella inbox)
$result           = session()->get('menuData');
$menu_items       = $result['result']       ?? [];
$dottori          = $result['dottori']      ?? [];
$contDott         = $result['cont_dottori'] ?? 0;
$selectedDoctorId = $selectedDoctorId       ?? null;
?>
