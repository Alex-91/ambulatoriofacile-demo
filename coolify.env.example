# Use this file as copy/paste source for Coolify environment variables.
# Recommended demo URL:
# - easiest: https://demo.ambulatoriofacile.it/
# - if the whole root domain is on Coolify: https://ambulatoriofacile.it/demo/

CI_ENVIRONMENT=production
RUN_MIGRATIONS=1
APP_MAINTENANCE_MODE=0
DEMO_SITE_ENABLED=1
BOOTSTRAP_DEMO_DB=1
RUN_DEMO_SEED=1
DEMO_SEED_PASSWORD=Demo2026
DEMO_SEED_AGENDA_BUSINESS_DAYS=5
DEMO_AUTO_RESET_ENABLED=1
DEMO_AUTO_RESET_HOUR=2
DEMO_AUTO_RESET_MINUTE=15
DEMO_AUTO_RESET_CHECK_INTERVAL=300
DEMO_AUTO_RESET_TZ=Europe/Rome
DEMO_PUBLIC_ROLE_SWITCH_ENABLED=1
DEMO_LOGIN_PREFILL_ENABLED=0
# Optional dedicated token for the nightly demo reset endpoint.
# If empty, the app falls back to CRON_ACCESS_TOKEN.
DEMO_RESET_ACCESS_TOKEN=CHANGE_ME

app.baseURL=https://demo.ambulatoriofacile.it/
APP_CANONICAL_URL=https://demo.ambulatoriofacile.it/
APP_PUBLIC_ACCESS_BASE_URL=
LEGACY_UPLOAD_PATH=/var/www/html/upload

# For the real multi-tenant production portal use:
# DEMO_SITE_ENABLED=0
# BOOTSTRAP_DEMO_DB=0
# DEMO_PUBLIC_ROLE_SWITCH_ENABLED=0
# DEMO_LOGIN_PREFILL_ENABLED=0
# app.baseURL=https://ambulatoriofacile.it/app/
# APP_CANONICAL_URL=https://ambulatoriofacile.it/app/
# APP_PUBLIC_ACCESS_BASE_URL=https://ambulatoriofacile.it/
# PLATFORM_MASTER_EMAILS=tuamail@dominio.it,amico@dominio.it

database.default.hostname=CHANGE_ME
database.default.database=CHANGE_ME
database.default.username=CHANGE_ME
database.default.password=CHANGE_ME
database.default.DBDriver=MySQLi
database.default.DBPrefix=
database.default.port=3306

database.default.DB_ENCRYPTION_KEY=CHANGE_ME_LONG_SECRET
DB_ENCRYPTION_KEY=CHANGE_ME_LONG_SECRET
DB_ENCRYPTION_MODE=aes-256-cbc

# Optional: central platform catalog DB.
# Leave empty to reuse the default database above.
PLATFORM_DB_HOST=
PLATFORM_DB_DATABASE=
PLATFORM_DB_USERNAME=
PLATFORM_DB_PASSWORD=
PLATFORM_DB_PORT=3306
PLATFORM_DB_DRIVER=MySQLi
PLATFORM_DB_PREFIX=
PLATFORM_DB_ENCRYPTION_KEY=
PLATFORM_MASTER_EMAILS=

FILE_CRYPT_ALGO=AES-256-CBC
FILE_CRYPT_KEY=CHANGE_ME_FILE_SECRET
FILE_CRYPT_IV=1234567890abcdef

email.fromEmail=noreply@ambulatoriofacile.it
email.fromName=AmbulatorioFacile
email.protocol=smtp
email.SMTPHost=CHANGE_ME
email.SMTPUser=CHANGE_ME
email.SMTPPass=CHANGE_ME
email.SMTPPort=465
email.SMTPCrypto=ssl
email.SMTPTimeout=10
email.mailType=text
email.charset=UTF-8

AUTH_HANDOFF_SECRET=CHANGE_ME
AUTH_HANDOFF_ISSUER=ambulatoriofacile-demo
AUTH_HANDOFF_CLOCK_SKEW=30
AUTH_HANDOFF_MAX_LIFETIME=120

CRON_ACCESS_TOKEN=CHANGE_ME
PUSH_MODE=remote
PUSH_REMOTE_URL=CHANGE_ME
PUSH_REMOTE_API_KEY=CHANGE_ME
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:noreply@ambulatoriofacile.it

# Multi-tenant central admin and provisioning
# Admin connection used to create databases / grants from the panel.
TENANT_PROVISIONING_ADMIN_HOST=
TENANT_PROVISIONING_ADMIN_PORT=3306
TENANT_PROVISIONING_ADMIN_USERNAME=
TENANT_PROVISIONING_ADMIN_PASSWORD=

# Runtime DB defaults used when a new tenant omits DB host/user in the panel.
TENANT_PROVISIONING_RUNTIME_HOST=
TENANT_PROVISIONING_RUNTIME_PORT=3306
TENANT_PROVISIONING_RUNTIME_USERNAME=
TENANT_PROVISIONING_RUNTIME_DRIVER=MySQLi

# The panel stores only the env var name, not the DB password itself.
# Example:
# - TENANT_PROVISIONING_RUNTIME_PASSWORD_REF=TENANT_SHARED_RUNTIME_PASSWORD
# - TENANT_SHARED_RUNTIME_PASSWORD=super-secret
TENANT_PROVISIONING_RUNTIME_PASSWORD_REF=
TENANT_SHARED_RUNTIME_PASSWORD=
TENANT_PROVISIONING_RUNTIME_USER_HOST=%

# Choose ONE template strategy for new client spaces:
# 1) clone a clean template database
TENANT_PROVISIONING_TEMPLATE_DATABASE=
# 2) or import a clean SQL template file already present inside the container
TENANT_PROVISIONING_TEMPLATE_SQL_PATH=
