<script>
  // Loader link & submit
  (function() {
    var loader = $('#page-loader');

    function showLoader(){ loader.stop(true,true).fadeIn(100); }
    function hideLoader(){ loader.stop(true,true).fadeOut(150); }

    window.__DRAFT_BLOCK_NAV__ = false;
    window.__HIDE_PAGE_LOADER__ = hideLoader;
    window.__SHOW_PAGE_LOADER__ = showLoader;

    $(document).on('click', 'a[href]:not([href^="#"]):not([target="_blank"]):not(.no-loader)', function(e){
      if (window.__DRAFT_BLOCK_NAV__) { hideLoader(); return; }
      if (e.ctrlKey || e.shiftKey || e.metaKey || (this.href && this.href.indexOf('javascript:') === 0)) return;

      var $a = $(this);
      if ($a.attr('data-toggle') === 'dropdown' || $a.attr('data-toggle') === 'collapse' || $a.data('widget') === 'collapse') return;
      showLoader();
    });

    $(document).on('submit', 'form:not(.no-loader)', function(){ showLoader(); });
    window.addEventListener('beforeunload', function(){ showLoader(); });
    $(window).on('load', function(){ hideLoader(); });
  })();
</script>

<script>
  // Allegati temp: render + load
  function renderAttachmentList(attachments) {
    var $list = $('#attachment-list');
    $list.empty();

    if (!attachments || !attachments.length) {
      $list.append('<li style="color:#999;">Nessun file selezionato</li>');
      return;
    }

    attachments.forEach(function(att) {
      var nomeVis =
        (att.nome_vis && att.nome_vis.trim() !== '') ? att.nome_vis :
        (att.nome_vis_enc && att.nome_vis_enc.trim() !== '') ? att.nome_vis_enc :
        (att.nome_real && att.nome_real.trim() !== '') ? att.nome_real :
        (att.nome_real_enc && att.nome_real_enc.trim() !== '') ? att.nome_real_enc :
        'Allegato';

      $list.append(
        '<li>' +
          '<span class="file-name"><i class="fa fa-paperclip"></i> ' + nomeVis + '</span>' +
          '<button type="button" class="btn btn-xs btn-danger remove-file" data-id="' + att.id_attachments + '">' +
            '<i class="fa fa-trash"></i> Rimuovi' +
          '</button>' +
        '</li>'
      );
    });
  }

  function loadAttachmentList() {
    $.getJSON('<?= site_url('posta/attachment/list') ?>', function(resp) {
      if (resp && resp.ok) {
        renderAttachmentList(resp.attachments);

        var $form = $('#compose-form');
        var csrfInput = $form.find('input[name^="csrf_"]').first();
        if (csrfInput.length && resp.csrfName && resp.csrfHash) {
          csrfInput.attr('name', resp.csrfName).val(resp.csrfHash);
        }
      }
    });
  }

  $(function () {
    var $form     = $('#compose-form');
    var $to       = $('.js-recipient');
    var $editorTA = $('#compose-textarea');
    var csrfInput = $form.find('input[name^="csrf_"]').first();
    var inboxUrl  = '<?= site_url('posta') ?>';
    var inviaUrl  = '<?= site_url('posta/send') ?>';

    function updateCsrfFromResp(resp) {
      if (resp && resp.csrfName && resp.csrfHash && csrfInput.length) {
        csrfInput.attr('name', resp.csrfName).val(resp.csrfHash);
      }
    }

    function getEditorHtml() {
      try {
        var w = $editorTA.data('wysihtml5');
        if (w && w.editor) return w.editor.getValue(true);
      } catch(e) {}
      return $editorTA.val();
    }

    // WYSIHTML5 (sempre)
    $('#compose-textarea').wysihtml5({ locale: 'it-IT' });

    // Select2 (solo non-paziente)
    if (!IS_PATIENT && $to.length) {
      $to.select2({
        placeholder: $to.data('placeholder') || 'Cerca destinatario...',
        minimumInputLength: 3,
        allowClear: true,
        ajax: {
          url: '<?= site_url('posta/contacts') ?>',
          type: 'POST',
          delay: 250,
          dataType: 'json',
          data: function (params) {
            var payload = { q: params.term };
            if (csrfInput.length) payload[csrfInput.attr('name')] = csrfInput.val();
            return payload;
          },
          processResults: function (data) { return { results: data }; },
          cache: true
        },
        width: 'resolve'
      });
    }

    // iCheck (se presenti checkbox)
    $('input[type="checkbox"]').iCheck({
      checkboxClass: 'icheckbox_flat-blue',
      radioClass: 'iradio_flat-blue'
    });

    // Lista allegati iniziale
    loadAttachmentList();

    // Upload allegati (sempre)
    $('#file-attachments').off('change').on('change', function () {
      var inputEl = this;
      var files = inputEl.files;
      if (!files || !files.length) return;

      var fd = new FormData();
      for (var i = 0; i < files.length; i++) fd.append('attachment[]', files[i]);

      var idMessageField = $('#hid-id_message');
      if (idMessageField.length) fd.append('id_message', idMessageField.val() || '');

      if (csrfInput.length) fd.append(csrfInput.attr('name'), csrfInput.val());

      inputEl.value = '';

      $('#page-loader .msg').text('Caricamento allegatiâ€¦');
      $('#page-loader').fadeIn(100);

      $.ajax({
        url: '<?= site_url('posta/attachment/upload') ?>',
        method: 'POST',
        data: fd,
        processData: false,
        contentType: false,
        dataType: 'json'
      }).done(function(resp) {
        $('#page-loader').fadeOut(150);

        if (resp && resp.ok) {
          renderAttachmentList(resp.attachments);
          updateCsrfFromResp(resp);
        } else {
          alert(resp && resp.err ? resp.err : 'Errore durante l\'upload degli allegati');
        }
      }).fail(function() {
        $('#page-loader').fadeOut(150);
        alert('Errore durante l\'upload degli allegati');
      });
    });

    // Rimozione allegato temp (sempre)
    $(document).on('click', '.remove-file', function (e) {
      e.preventDefault();
      var id = $(this).data('id');
      if (!id) return;

      var fd = new FormData();
      fd.append('id_attachments', id);
      if (csrfInput.length) fd.append(csrfInput.attr('name'), csrfInput.val());

      $('#page-loader .msg').text('Rimozione allegatoâ€¦');
      $('#page-loader').fadeIn(100);

      $.ajax({
        url: '<?= site_url('posta/attachment/delete') ?>',
        method: 'POST',
        data: fd,
        processData: false,
        contentType: false,
        dataType: 'json'
      }).done(function(resp) {
        $('#page-loader').fadeOut(150);

        if (resp && resp.ok) {
          renderAttachmentList(resp.attachments);
          updateCsrfFromResp(resp);
        } else {
          alert(resp && resp.err ? resp.err : 'Errore durante la rimozione dell\'allegato');
        }
      }).fail(function() {
        $('#page-loader').fadeOut(150);
        alert('Errore durante la rimozione dell\'allegato');
      });
    });

    // Submit invio (sempre)
    $form.off('submit').on('submit', function(e){
      e.preventDefault();

      $('#page-loader .msg').text('Invio in corsoâ€¦');
      $('#page-loader').fadeIn(100);

      var fd = new FormData($form.get(0));
      fd.set('message_text', getEditorHtml());
      fd.set('version', window.matchMedia('(max-width: 767px)').matches ? 'mobile' : 'desktop');
      fd.set('count_div', '0');

      if (!IS_PATIENT && $to.length) {
        var ids = ($to.val() || []).map(function(v){ return String(v).trim(); }).filter(Boolean);
        fd.set('string_dest', ids.length ? (',' + ids.join(',')) : '');
      } else {
        fd.set('string_dest', '');
      }

      $.ajax({
        url: inviaUrl,
        method: 'POST',
        data: fd,
        processData: false,
        contentType: false,
        cache: false,
        dataType: 'json'
      })
      .done(function(resp) {
        $('#page-loader').fadeOut(150, function(){
          var showPatientNotice = (resp && typeof resp.showPatientNotice !== 'undefined')
                                  ? !!resp.showPatientNotice
                                  : IS_PATIENT;

          if (showPatientNotice) {
            $("#messageSendDialogPazienteSegreteria").dialog({
              modal: true,
              width: 600,
              show: { effect: "fadeIn", duration: 300 },
              open: function () { $(this).css({ "font-size": "22px" }); },
              buttons: {
                "Ok letto": function() {
                  $(this).dialog("close");
                  $('#page-loader .msg').text('Ritorno alla postaâ€¦');
                  $('#page-loader').fadeIn(100, function(){ window.location = inboxUrl; });
                }
              }
            });
          } else {
            $('#page-loader .msg').text('Ritorno alla postaâ€¦');
            $('#page-loader').fadeIn(100, function(){ window.location = inboxUrl; });
          }
        });

        updateCsrfFromResp(resp);
      })
      .fail(function() {
        $('#page-loader').fadeOut(150);
        alert('Errore durante lâ€™invio del messaggio. Riprova.');
      });
    });

    // =====================================================================
    // âœ… BOZZE SOLO DOTTORI/PERSONALE (paziente: qui non entra)
    // =====================================================================
    if (DRAFT_ENABLED) {

      // endpoints (usa le tue rotte reali)
      var DRAFT_CREATE_URL = '<?= site_url('draft/create') ?>';
      var DRAFT_SAVE_URL   = '<?= site_url('draft/save') ?>';
      var DRAFT_DELETE_URL = '<?= site_url('draft/delete') ?>';

      var draftId     = parseInt($('#hid-draft-id').val() || '0', 10);
      var sessid      = $('#hid-sessid').val() || '';
      var dirty       = false;
      var saving      = false;
      var allowLeave  = false;
      var pendingHref = null;
      var debounceT   = null;

      var openedFromDraft = (DRAFT_ID && DRAFT_DATA) ? true : false;
      if (openedFromDraft) {
        draftId = parseInt(DRAFT_ID, 10) || draftId;
        $('#hid-draft-id').val(draftId);
        $('#hid-id_message').val(String(draftId));
      }

      function csrfPayload(obj) {
        obj = obj || {};
        if (csrfInput.length) obj[csrfInput.attr('name')] = csrfInput.val();
        return obj;
      }

      function setDraftId(id) {
        draftId = parseInt(id || 0, 10) || 0;
        $('#hid-draft-id').val(draftId);
        $('#hid-id_message').val(draftId ? String(draftId) : '');
      }

      function markDirty(){ dirty = true; }

      function debounceSave() {
        markDirty();
        clearTimeout(debounceT);
        debounceT = setTimeout(function(){ saveDraft(false); }, 1500);
      }

      function buildDraftMeta() {
        var meta = {};
        meta.version = window.matchMedia('(max-width: 767px)').matches ? 'mobile' : 'desktop';

        var ids = ($to.val() || []).map(function(v){ return String(v).trim(); }).filter(Boolean);
        meta.string_dest = ids.length ? (',' + ids.join(',')) : '';

        meta.recipients = [];
        $to.find('option:selected').each(function(){
          meta.recipients.push({ id: $(this).val(), text: $(this).text() });
        });

        return meta;
      }

      function ensureDraftId(cb) {
        if (draftId > 0) return cb && cb();
        if (openedFromDraft) return cb && cb();

        var payload = csrfPayload({ sessid: sessid });

        $.ajax({
          url: DRAFT_CREATE_URL,
          method: 'POST',
          data: payload,
          dataType: 'json'
        }).done(function(resp){
          if (resp && resp.ok && resp.draftId) {
            setDraftId(resp.draftId);
            updateCsrfFromResp(resp);
          }
          if (cb) cb();
        }).fail(function(){ if (cb) cb(); });
      }

      function saveDraft(force) {
        if (saving) return;
        if (!force && !dirty) return;

        ensureDraftId(function(){
          if (!draftId) return;

          saving = true;
          var meta = buildDraftMeta();

          var payload = csrfPayload({
            draftId: draftId,
            testo: getEditorHtml(),
            meta: JSON.stringify(meta)
          });

          $.ajax({
            url: DRAFT_SAVE_URL,
            method: 'POST',
            data: payload,
            dataType: 'json'
          }).done(function(resp){
            saving = false;
            if (resp && resp.ok) dirty = false;
            updateCsrfFromResp(resp);
          }).fail(function(){ saving = false; });
        });
      }

      // âœ… Salva con loader + OK (tasto "Bozza")
      function saveDraftWithFeedback() {
        markDirty();

        $('#page-loader .msg').text('Salvataggio bozzaâ€¦');
        $('#page-loader').fadeIn(100);

        ensureDraftId(function(){
          if (!draftId) {
            $('#page-loader').fadeOut(150);
            alert('Impossibile salvare la bozza (id non valido).');
            return;
          }

          saving = true;
          var meta = buildDraftMeta();

          var payload = csrfPayload({
            draftId: draftId,
            testo: getEditorHtml(),
            meta: JSON.stringify(meta)
          });

          $.ajax({
            url: DRAFT_SAVE_URL,
            method: 'POST',
            data: payload,
            dataType: 'json'
          }).done(function(resp){
            saving = false;
            $('#page-loader').fadeOut(150);

            if (resp && resp.ok) {
              dirty = false;
              updateCsrfFromResp(resp);
              alert('Bozza salvata âœ…');
            } else {
              updateCsrfFromResp(resp);
              alert(resp && resp.err ? resp.err : 'Errore durante il salvataggio della bozza.');
            }
          }).fail(function(){
            saving = false;
            $('#page-loader').fadeOut(150);
            alert('Errore durante il salvataggio della bozza.');
          });
        });
      }

      function deleteDraftAndExit() {
        if (!draftId) {
          allowLeave = true;
          if (pendingHref) window.location = pendingHref;
          return;
        }

        var payload = csrfPayload({ draftId: draftId });

        $('#page-loader .msg').text('Eliminazione bozzaâ€¦');
        $('#page-loader').fadeIn(100);

        $.ajax({
          url: DRAFT_DELETE_URL,
          method: 'POST',
          data: payload,
          dataType: 'json'
        }).done(function(resp){
          $('#page-loader').fadeOut(150);
          updateCsrfFromResp(resp);
          allowLeave = true;
          if (pendingHref) window.location = pendingHref;
        }).fail(function(){
          $('#page-loader').fadeOut(150);
          allowLeave = true;
          if (pendingHref) window.location = pendingHref;
        });
      }

      function keepDraftAndExit() {
        saveDraft(true);
        allowLeave = true;
        if (pendingHref) window.location = pendingHref;
      }

      function openExitDialog(href) {
        pendingHref = href;
        $("#exitDraftDialog").dialog({
          modal: true,
          width: 520,
          buttons: {
            "Elimina bozza": function() {
              $(this).dialog("close");
              deleteDraftAndExit();
            },
            "Tieni in bozze": function() {
              $(this).dialog("close");
              keepDraftAndExit();
            }
          }
        });
      }

      // âœ… RIPRISTINO TESTO BOZZA (robusto, anche se l'editor non Ã¨ pronto subito)
      function getDraftTextFromData() {
        if (!DRAFT_DATA) return '';
        return String((DRAFT_DATA.testo ?? DRAFT_DATA.body ?? DRAFT_DATA.message ?? DRAFT_DATA.testo_dec ?? ''));
      }

      function setEditorTextRobust(html) {
        html = html || '';

        // fallback textarea
        $editorTA.val(html);

        // retry fino a quando wysihtml5 Ã¨ pronto
        var tries = 0;
        var t = setInterval(function () {
          tries++;
          try {
            var w = $editorTA.data('wysihtml5');
            if (w && w.editor) {
              w.editor.setValue(html, true);
              clearInterval(t);
            }
          } catch(e) {}

          if (tries >= 20) clearInterval(t); // ~2s
        }, 100);
      }

      if (openedFromDraft) {
        var txt = getDraftTextFromData();
        if (txt && txt.trim() !== '') setEditorTextRobust(txt);
      }

      // Ripristino destinatari da meta (se il controller passa draftData.meta.recipients)
      if (openedFromDraft && DRAFT_DATA && DRAFT_DATA.meta && Array.isArray(DRAFT_DATA.meta.recipients)) {
        DRAFT_DATA.meta.recipients.forEach(function(r){
          if (!r || !r.id) return;
          var opt = new Option(r.text || ('#'+r.id), String(r.id), true, true);
          $to.append(opt);
        });
        $to.trigger('change');
      }

      // Hook cambi: editor
      setTimeout(function(){
        try {
          var w = $editorTA.data('wysihtml5');
          if (w && w.editor) {
            w.editor.on('change', function(){ debounceSave(); });
            w.editor.on('keyup', function(){ debounceSave(); });
          }
        } catch(e) {}
      }, 300);

      // Hook cambi: select2 e textarea fallback
      $to.on('change', function(){ debounceSave(); });
      $editorTA.on('input', function(){ debounceSave(); });

      // Crea draft subito solo se NON sto aprendo bozza esistente
      if (!openedFromDraft) ensureDraftId(function(){});

      // Autosave
      setInterval(function(){ saveDraft(false); }, 15000);

      // âœ… Bottone Bozza: loader + ok
      $('#btn-draft').off('click').on('click', function(e){
        e.preventDefault();
        saveDraftWithFeedback();
      });

      // Fix loader + dialog uscita: quando nav con bozza sporca
      function interceptNavClick(e, href) {
        if (allowLeave) return false;
        if (!dirty) return false;

        e.preventDefault();
        window.__DRAFT_BLOCK_NAV__ = true;
        if (window.__HIDE_PAGE_LOADER__) window.__HIDE_PAGE_LOADER__();
        setTimeout(function(){ window.__DRAFT_BLOCK_NAV__ = false; }, 0);

        openExitDialog(href);
        return true;
      }

      $(document).on('click', 'a[href]:not([href^="#"]):not([target="_blank"]):not(.no-loader)', function(e){
        if (allowLeave) return;
        var $a = $(this);
        if ($a.attr('data-toggle') === 'dropdown' || $a.attr('data-toggle') === 'collapse' || $a.data('widget') === 'collapse') return;

        var href = $a.attr('href');
        if (!href) return;
        interceptNavClick(e, href);
      });

      $('#btn-annulla').on('click', function(e){
        if (allowLeave) return;
        var href = $(this).attr('href') || inboxUrl;
        interceptNavClick(e, href);
      });

      // beforeunload best-effort save
      window.addEventListener('beforeunload', function(e){
        if (allowLeave) return;
        if (!dirty) return;

        try {
          var meta = buildDraftMeta();
          var payload = csrfPayload({
            draftId: draftId || '',
            testo: getEditorHtml(),
            meta: JSON.stringify(meta)
          });

          var enc = [];
          for (var k in payload) if (payload.hasOwnProperty(k)) enc.push(encodeURIComponent(k)+'='+encodeURIComponent(payload[k]));
          var blob = new Blob([enc.join('&')], {type:'application/x-www-form-urlencoded'});
          if (navigator.sendBeacon) navigator.sendBeacon(DRAFT_SAVE_URL, blob);
        } catch(err) {}

        e.preventDefault();
        e.returnValue = '';
      });

      // se riapro bozza: non sporco finchÃ© non tocchi
      if (openedFromDraft) dirty = false;
    }
  });
</script>

</body>
</html>
