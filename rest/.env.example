#--------------------------------------------------------------------
# Example environment configuration for local, demo, and production
# Copy this file to `.env` in each installation and fill real values.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
app.baseURL = 'http://localhost/'
app.indexPage = ''
APP_CANONICAL_URL = 'https://example.com/'

#--------------------------------------------------------------------
# APP MAINTENANCE
#--------------------------------------------------------------------
APP_MAINTENANCE_MODE = 0
APP_MAINTENANCE_BYPASS_TOKEN = "change-me"
APP_MAINTENANCE_BYPASS_COOKIE_MINUTES = 480
APP_MAINTENANCE_TITLE = "Sito in manutenzione"
APP_MAINTENANCE_MESSAGE = "Stiamo facendo un intervento tecnico. Riprova tra poco."
# APP_MAINTENANCE_ALLOWED_IPS = "127.0.0.1"

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = app_database
database.default.username = app_user
database.default.password = change-me
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Keep aligned with DB_ENCRYPTION_KEY if both are used by the app.
database.default.DB_ENCRYPTION_KEY = change-me
DB_ENCRYPTION_KEY = change-me
DB_ENCRYPTION_MODE = aes-256-cbc

#--------------------------------------------------------------------
# FILE / DATA ENCRYPTION
#--------------------------------------------------------------------
FILE_CRYPT_ALGO = AES-256-CBC
FILE_CRYPT_KEY = change-me
FILE_CRYPT_IV = 1234567890abcdef
crypto.key_hex =
crypto.iv_hex =

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------
email.fromEmail = noreply@example.com
email.fromName = Ambulatori
email.protocol = smtp
email.SMTPHost = smtp.example.com
email.SMTPUser = noreply@example.com
email.SMTPPass = change-me
email.SMTPPort = 465
# Leave empty on port 465 for implicit TLS; use tls on port 587.
email.SMTPCrypto =
email.SMTPTimeout = 10
email.mailType = text
email.charset = UTF-8

#--------------------------------------------------------------------
# SMS / WHATSAPP / REMINDERS
#--------------------------------------------------------------------
SMS_API_TOKEN =
SMS_USERNAME =
SMS_PASSWORD =
SMS_ULTRAMSG_URL =
SMS_BATCH_DELAY_MS = 900000
REMINDER_CHANNEL = wa
CRON_ACCESS_TOKEN = change-me

#--------------------------------------------------------------------
# WEB PUSH
#--------------------------------------------------------------------
PUSH_MODE = remote
PUSH_REMOTE_URL = https://push.example.com/api/send
PUSH_REMOTE_API_KEY = change-me
VAPID_PUBLIC_KEY =
VAPID_SUBJECT = mailto:admin@example.com
# PUSH_VERCEL_BYPASS_TOKEN =

#--------------------------------------------------------------------
# CROSS-APP LOGIN HANDOFF
#--------------------------------------------------------------------
AUTH_HANDOFF_SECRET = change-me
AUTH_HANDOFF_ISSUER = ambulatori-cloud-legacy
AUTH_HANDOFF_CLOCK_SKEW = 30
AUTH_HANDOFF_MAX_LIFETIME = 120

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
# logger.threshold = 4
