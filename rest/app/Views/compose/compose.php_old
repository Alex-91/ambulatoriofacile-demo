<script>
  const IS_PATIENT     = <?= $isPatient ? 'true' : 'false' ?>;
  const DRAFT_ENABLED  = <?= $draftEnabled ? 'true' : 'false' ?>;

  // Dati bozza (solo se dottore/personale)
  const DRAFT_ID   = <?= ($draftEnabled && $draftId) ? (int)$draftId : 0 ?>;
  const DRAFT_DATA = <?= ($draftEnabled && $draftData) ? json_encode($draftData, JSON_UNESCAPED_UNICODE|JSON_UNESCAPED_SLASHES) : 'null' ?>;
</script>

