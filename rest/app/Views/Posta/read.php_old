                    <?php if (!empty($threadMsgs)): ?>
                      <?php
                        $prevDay    = null;
                        $utenteSess = session()->get('utente_sess');
                        $myId       = (int)($utenteSess->id_personale ?? 0); // usato per colorare "me"

                        foreach ($threadMsgs as $m):
                          $mDT     = isset($m['dataora']) ? Time::parse($m['dataora'], $tz) : null;
                          $mWhen   = $mDT ? $mDT->toLocalizedString('d MMM y HH:mm') : '';
                          $dayKey  = $mDT ? $mDT->toDateString() : '';
                          $isHtmlM = !empty($m['is_html'] ?? false);
                          $fromM   = trim(($m['mitt_prefix'] ?? '') . ' ' . ($m['mittente_cognome'] ?? '') . ' ' . ($m['mittente_nome'] ?? '')) ?: 'Mittente';
                          $allegM  = $m['allegati'] ?? [];
                          $isMe    = $myId && isset($m['id_mitt']) && ((int)$m['id_mitt'] === $myId);

                          if ($dayKey && $dayKey !== $prevDay):
                            $prevDay = $dayKey; ?>
                            <div class="day-sep"><?= esc($mDT->toLocalizedString('EEEE d MMM y')) ?></div>
                          <?php endif; ?>

                          <div class="thread-item">
                            <div class="thread-head">
                              <div class="thread-from"><?= esc($fromM) ?></div>
                              <div class="thread-time"><?= esc($mWhen) ?></div>
                            </div>
                            <div class="bubble <?= $isMe ? 'me' : '' ?>">
                              <?php if ($isHtmlM): ?>
                                <?= $m['testo'] ?? '' ?>
                              <?php else: ?>
                                <div><?= nl2br(esc($m['testo'] ?? '')) ?></div>
                              <?php endif; ?>

                              <?php if (!empty($allegM)): ?>
                                <div class="thread-att">
                                  <?php foreach ($allegM as $att): ?>
                                    <?php
                                      $tipo        = strtolower($att['tipo'] ?? '');
                                      $isImg       = in_array($tipo, ['png','jpg','jpeg','gif','webp','bmp']);
                                      $viewUrl     = $att['url'];                  // /posta/attachment/:id  (proxy)
                                      $downloadUrl = $att['url'] . '?download=1';  // forza download
                                    ?>
                                    <div class="thread-att-item">
                                      <a href="<?= esc($viewUrl) ?>" target="_blank" class="thread-att-preview no-loader">
                                        <?php if ($isImg): ?>
                                          <img src="<?= esc($viewUrl) ?>"
                                               alt="<?= esc($att['nome'] ?? 'allegato') ?>">
                                        <?php else: ?>
                                          <div class="thread-att-item-icon">
                                            <i class="fa fa-file-o"></i>
                                          </div>
                                        <?php endif; ?>
                                        <div class="thread-att-item-name">
                                          <?= esc($att['nome'] ?? 'allegato') ?>
                                        </div>
